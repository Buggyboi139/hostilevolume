{
  "id": "level-29",
  "title": "Precarious Pitch",
  "display": "flex",
  "html": "        <div id=\"level-29\" class=\"level-ui hidden flex-col items-center justify-center w-full gap-2 relative mt-2\">\n            <div class=\"text-[10px] sm:text-xs tracking-widest text-teal-400 uppercase font-bold text-center animate-pulse mb-1 shrink-0\">Precarious Pitch</div>\n            <p class=\"text-[9px] sm:text-[10px] text-gray-400 font-mono mb-2 text-center shrink-0\">Hold the slider to tilt the beam. Balance at 25%.<br>Do not drop the ball.</p>\n            \n            <div class=\"flex flex-row items-center justify-center gap-4 w-full h-40 sm:h-48 relative\">\n                <div class=\"relative w-full max-w-[240px] h-full bg-gray-950 rounded-xl overflow-hidden border-2 border-gray-700 shadow-[0_0_15px_rgba(0,0,0,0.5)]\">\n                    <canvas id=\"l29-canvas\" class=\"w-full h-full block touch-none\"></canvas>\n                </div>\n                \n                <div class=\"relative h-full w-10 sm:w-12 shrink-0 bg-gray-950 rounded-full border-2 border-gray-800 shadow-inner flex items-center justify-center\">\n                    <input type=\"range\" min=\"-100\" max=\"100\" value=\"0\" class=\"w-32 sm:w-40 h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-teal-400 absolute origin-center focus:outline-none\" id=\"l29-slider\" style=\"transform: rotate(-90deg);\">\n                </div>\n            </div>\n\n            <div class=\"mt-2 text-4xl font-mono text-gray-300 text-center w-full shrink-0 transition-colors\" id=\"l29-display\">75%</div>\n        </div>"
}
