{
  "id": "level-20",
  "title": "Compositor",
  "display": "flex",
  "html": "        <div id=\"level-20\" class=\"level-ui hidden flex-col items-center justify-center w-full transition-all duration-300 gap-1.5 sm:gap-2 h-full py-2\">\n            <div class=\"text-[9px] sm:text-[10px] tracking-widest text-red-500 uppercase font-bold mb-1 text-center animate-pulse\">Compositor</div>\n            <div class=\"w-full flex items-center justify-between gap-2 sm:gap-3\"><span class=\"w-4 font-bold text-red-400 text-[10px] sm:text-xs\">A</span><input type=\"range\" id=\"l20-A\" min=\"0\" max=\"100\" value=\"25\" class=\"flex-1 h-1.5 bg-gray-800 appearance-none accent-red-500 cursor-pointer\"></div>\n            <div class=\"w-full flex items-center justify-between gap-2 sm:gap-3\"><span class=\"w-4 font-bold text-blue-400 text-[10px] sm:text-xs\">B</span><input type=\"range\" id=\"l20-B\" min=\"0\" max=\"100\" value=\"75\" class=\"flex-1 h-1.5 bg-gray-800 appearance-none accent-blue-500 cursor-pointer\"></div>\n            <div class=\"w-full flex items-center justify-center gap-3 sm:gap-4 py-1.5 border-y border-gray-800 my-1 relative\"><span class=\"absolute left-0 w-4 font-bold text-green-400 text-[10px] sm:text-xs\">C</span><button id=\"l20-C-down\" class=\"bg-gray-800 hover:bg-gray-700 px-2 sm:px-3 py-1 rounded text-white font-bold transition-transform focus:outline-none\">-</button><span id=\"l20-C-val\" class=\"font-mono text-xs sm:text-sm w-6 text-center text-gray-500\">75</span><button id=\"l20-C-up\" class=\"bg-gray-800 hover:bg-gray-700 px-2 sm:px-3 py-1 rounded text-white font-bold transition-transform focus:outline-none\">+</button></div>\n            <div class=\"w-full flex items-center justify-between gap-2 sm:gap-3\"><span class=\"w-4 font-bold text-yellow-400 text-[10px] sm:text-xs\">D</span><input type=\"range\" id=\"l20-D\" min=\"0\" max=\"100\" value=\"75\" class=\"flex-1 h-1.5 bg-gray-800 appearance-none accent-yellow-500 cursor-pointer\"></div>\n            <div class=\"w-full flex items-center justify-between gap-2 sm:gap-3 relative mt-2 sm:mt-0\"><span class=\"w-4 font-bold text-purple-400 text-[10px] sm:text-xs\">E</span><input type=\"range\" id=\"l20-E\" min=\"0\" max=\"100\" value=\"75\" class=\"flex-1 h-1.5 bg-gray-800 appearance-none accent-purple-500 pointer-events-none opacity-50 transition-all duration-200\"><div class=\"absolute right-0 -top-3 sm:-top-4 text-[7px] sm:text-[8px] text-purple-400 tracking-widest uppercase\">Auto-RNG</div></div>\n            <div class=\"mt-3 sm:mt-4 text-4xl sm:text-5xl font-mono text-white text-center drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]\" id=\"l20-display\">75%</div>\n        </div>"
}
