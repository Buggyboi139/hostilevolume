  "display": "flex",
  "html": "<div id=\"level-26\" class=\"level-ui hidden flex-col items-center justify-center w-full gap-4 relative mt-2\">\n            <div class=\"text-[10px] sm:text-xs tracking-widest text-indigo-500 uppercase font-bold text-center animate-pulse mb-1 shrink-0\">Artillery Strike</div>\n            <p class=\"text-[9px] sm:text-[10px] text-gray-400 font-mono mb-2 text-center shrink-0\">Drag back to aim and fire. Hit the green 25% mark.<br>Mind the moving target.</p>\n            \n            <div class=\"relative w-full max-w-sm aspect-square shrink-0 bg-sky-950 rounded-xl overflow-hidden border-2 border-gray-700 shadow-inner mx-auto\">\n                <div class=\"absolute inset-0 pointer-events-none opacity-20 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-white to-transparent\"></div>\n                <canvas id=\"l26-canvas\" class=\"w-full h-full block cursor-crosshair touch-none relative z-10\"></canvas>\n            </div>\n\n            <div class=\"mt-2 text-4xl font-mono text-gray-300 text-center w-full shrink-0\" id=\"l26-display\">75%</div>\n        </div>"
