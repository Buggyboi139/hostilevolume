  "display": "flex",
  "html": "        <div id=\"level-15\" class=\"level-ui hidden flex-col items-center justify-center gap-6 sm:gap-8 w-full min-h-[220px] relative\">\n            <div class=\"absolute top-0 w-full text-[10px] sm:text-xs tracking-widest text-amber-500 uppercase font-bold text-center animate-pulse shrink-0\">Metronome of Madness</div>\n            \n            <div class=\"w-full relative h-8 sm:h-10 shrink-0 bg-gray-950 rounded-full border border-gray-800 overflow-hidden shadow-inner flex items-center mt-6\">\n                <div class=\"absolute top-0 bottom-0 w-1.5 bg-green-500/40 left-[25%] z-0\"></div>\n                <div id=\"l15-needle\" class=\"absolute top-0 bottom-0 w-2 bg-red-500 shadow-[0_0_12px_rgba(239,68,68,0.9)] left-[75%] z-10 -ml-1 transition-none rounded-full\"></div>\n            </div>\n            \n            <div class=\"text-4xl font-mono text-gray-300 w-24 text-center shrink-0\" id=\"l15-display\">75%</div>\n            <button id=\"l15-btn\" class=\"bg-yellow-600 hover:bg-yellow-500 active:bg-yellow-700 text-white font-bold py-3 px-10 sm:px-12 rounded-xl shadow-lg transition-transform focus:outline-none tracking-widest uppercase select-none cursor-pointer touch-none shrink-0\">Hold to Lock</button>\n        </div>"
