{
  "id": "level-16",
  "title": "Terms and Conditions",
  "display": "flex",
  "html": "        <div id=\"level-16\" class=\"level-ui hidden flex-col items-center justify-center w-full gap-4 transition-all duration-300 relative\">\n            <div class=\"text-[10px] sm:text-xs tracking-widest text-emerald-500 uppercase font-bold text-center animate-pulse mb-1 shrink-0\">Terms and Conditions</div>\n            <div id=\"l16-form-container\" class=\"w-full flex flex-col items-center gap-2 sm:gap-3\">\n                <h3 id=\"l16-form-title\" class=\"text-[11px] sm:text-[13px] font-bold text-red-400 uppercase tracking-wider w-full text-left\"></h3>\n                <div id=\"l16-form-text\" class=\"h-20 sm:h-24 w-full bg-gray-950 border border-gray-800 rounded p-2 overflow-y-auto text-[10px] text-gray-400 font-sans text-left select-none shadow-inner leading-relaxed transition-colors duration-300\"></div>\n                <div class=\"relative w-full h-20 sm:h-24\" id=\"l16-canvas-wrapper\">\n                    <canvas id=\"l16-signature-pad\" class=\"bg-gray-200 rounded cursor-crosshair touch-none w-full h-full shadow-inner block\"></canvas>\n                    <span class=\"absolute bottom-2 left-2 text-gray-500 text-xs pointer-events-none font-bold\">X_________________</span>\n                </div>\n                <div class=\"flex gap-2 w-full mt-1\">\n                    <button id=\"l16-clear-btn\" class=\"bg-gray-800 hover:bg-gray-700 active:bg-gray-600 text-white py-2 px-3 sm:px-4 rounded font-bold text-xs sm:text-sm w-1/3 transition-colors focus:outline-none\">Clear</button>\n                    <button id=\"l16-submit-btn\" class=\"bg-blue-700 hover:bg-blue-600 active:bg-blue-800 text-white py-2 px-3 sm:px-4 rounded font-bold text-xs sm:text-sm w-2/3 shadow-lg transition-transform active:scale-95 focus:outline-none\">Sign & Proceed</button>\n                </div>\n            </div>\n            <div id=\"l16-reward-container\" class=\"hidden w-full flex-col justify-center h-40 sm:h-48\">\n                <h3 class=\"text-green-500 font-bold mb-6 uppercase tracking-widest text-center text-[10px] sm:text-xs animate-pulse\">Compliance Acknowledged.</h3>\n                <input type=\"range\" min=\"0\" max=\"100\" value=\"75\" class=\"w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-green-500\" id=\"l16-reward-slider\">\n                <div class=\"mt-8 text-4xl font-mono text-gray-300 text-center\" id=\"l16-display\">75%</div>\n            </div>\n        </div>"
}
