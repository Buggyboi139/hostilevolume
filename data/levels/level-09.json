  "title": "Prove Your Humanity",
  "display": "flex",
  "html": "        <div id=\"level-9\" class=\"level-ui hidden h-40 sm:h-48 flex-col justify-center relative\">\n            <div class=\"absolute top-0 w-full text-[10px] sm:text-xs tracking-widest text-indigo-400 uppercase font-bold text-center animate-pulse shrink-0\">Prove Your Humanity</div>\n            <input type=\"range\" min=\"0\" max=\"100\" value=\"75\" class=\"w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-blue-500 mt-6\" id=\"l9-slider\">\n            <div class=\"mt-8 text-4xl font-mono text-gray-300 text-center\" id=\"l9-display\">75%</div>\n            <div id=\"l9-captcha-modal\" class=\"absolute inset-0 bg-gray-900 bg-opacity-95 flex items-center justify-center hidden z-20 rounded-xl\">\n                <div class=\"bg-gray-100 p-3 sm:p-4 rounded-sm shadow-md flex items-center gap-3 sm:gap-4 w-[90%] sm:w-72 border border-gray-300 select-none\">\n                    <div id=\"l9-checkbox\" class=\"w-7 h-7 sm:w-8 sm:h-8 border-2 border-gray-400 bg-white rounded-sm cursor-pointer flex items-center justify-center hover:shadow-inner transition-all flex-shrink-0\">\n                        <svg id=\"l9-check-icon\" class=\"w-5 h-5 sm:w-6 sm:h-6 text-green-600 hidden\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M5 13l4 4L19 7\"></path></svg>\n                        <svg id=\"l9-spinner-icon\" class=\"w-5 h-5 sm:w-6 sm:h-6 text-blue-600 animate-spin hidden\" fill=\"none\" viewBox=\"0 0 24 24\"><circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle><path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z\"></path></svg>\n                    </div>\n                    <span class=\"text-gray-800 font-sans text-[13px] sm:text-[15px] font-medium whitespace-nowrap\">I'm not a robot</span>\n                    <div class=\"ml-auto flex flex-col items-center justify-center pl-1 sm:pl-2\">\n                        <div class=\"text-[9px] sm:text-[10px] text-gray-500 font-bold tracking-widest leading-none mb-1\">reCAPTCHA</div>\n                        <div class=\"text-[7px] sm:text-[8px] text-gray-400\">Privacy - Terms</div>\n                    </div>\n                </div>\n            </div>\n        </div>"
