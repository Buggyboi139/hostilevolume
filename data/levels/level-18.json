{
  "id": "level-18",
  "title": "Customer Support",
  "display": "flex",
  "html": "        <div id=\"level-18\" class=\"level-ui hidden flex-col items-center justify-center w-full relative h-64 sm:h-[300px]\">\n            <div class=\"absolute top-0 w-full text-[10px] sm:text-xs tracking-widest text-sky-400 uppercase font-bold text-center animate-pulse shrink-0\">Customer Support</div>\n            <div id=\"l18-chat-box\" class=\"w-full h-40 sm:h-48 bg-gray-950 border border-gray-800 rounded-lg p-3 overflow-y-auto mb-3 text-[11px] sm:text-xs font-mono text-gray-400 flex flex-col gap-2 shadow-inner mt-6\">\n                <div><span class=\"text-blue-400 font-bold\">System:</span> Manual overrides restricted. Speak to an agent.</div>\n            </div>\n            <div class=\"flex gap-2 w-full\">\n                <input type=\"text\" id=\"l18-input\" class=\"flex-1 bg-gray-800 border border-gray-700 rounded px-2 sm:px-3 py-2 text-xs sm:text-sm focus:outline-none text-white placeholder-gray-500\" placeholder=\"Request volume...\">\n                <button id=\"l18-send\" class=\"bg-blue-600 hover:bg-blue-500 text-white px-3 sm:px-4 py-2 rounded text-xs sm:text-sm font-bold transition-colors focus:outline-none\">Send</button>\n            </div>\n            <button id=\"l18-confirm\" class=\"absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-green-500 hover:bg-green-400 text-white font-black tracking-widest py-4 px-8 sm:py-6 sm:px-12 rounded-2xl shadow-2xl hidden z-20 scale-110 focus:outline-none border-4 border-green-700 text-lg sm:text-xl\">CONFIRM</button>\n            <div class=\"mt-4 text-4xl font-mono text-gray-300 text-center hidden\" id=\"l18-display\">75%</div>\n        </div>"
}
