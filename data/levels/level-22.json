  "title": "Wheel of Misfortune",
  "display": "flex",
  "html": "        <div id=\"level-22\" class=\"level-ui hidden flex-col items-center justify-center w-full gap-4 relative mt-2\">\n            <div class=\"text-[10px] sm:text-xs tracking-widest text-pink-500 uppercase font-bold text-center animate-pulse mb-1 shrink-0\">Wheel of Misfortune</div>\n            <div class=\"relative w-56 h-56 sm:w-64 sm:h-64 shrink-0 mx-auto\">\n                <div class=\"absolute top-0 left-1/2 transform -translate-x-1/2 -mt-3 z-20 w-0 h-0 border-l-[12px] border-r-[12px] border-t-[24px] border-l-transparent border-r-transparent border-t-red-500 drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]\"></div>\n                <canvas id=\"l22-canvas\" width=\"400\" height=\"400\" class=\"w-full h-full rounded-full border-4 border-gray-800 shadow-[0_0_30px_rgba(0,0,0,0.9)] cursor-grab touch-none\"></canvas>\n            </div>\n            <div class=\"flex flex-col items-center gap-2 w-full\">\n                <button id=\"l22-spin-btn\" class=\"bg-pink-700 hover:bg-pink-600 active:bg-pink-800 text-white text-[10px] font-black tracking-[0.2em] uppercase py-2 px-8 rounded-full border-b-4 border-pink-900 active:border-b-0 active:translate-y-1 transition-all focus:outline-none\">Spin to Win</button>\n                <div class=\"text-4xl font-mono text-gray-300 text-center w-full shrink-0\" id=\"l22-display\">75%</div>\n            </div>\n        </div>"
}
