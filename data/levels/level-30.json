  "id": "level-30",
  "title": "Bureaucracy Simulator: Final Audit",
  "display": "flex",
  "html": "        <div id=\"level-30\" class=\"level-ui hidden flex-col items-center justify-center w-full gap-2 relative mt-2\">\n            <div class=\"text-[10px] sm:text-xs tracking-widest text-gray-400 uppercase font-bold text-center animate-pulse mb-1 shrink-0\">Bureaucracy Simulator: Final Audit</div>\n            \n            <div id=\"l30-form-container\" class=\"w-full bg-gray-950 border border-gray-700 rounded-xl p-3 flex flex-col shadow-inner text-xs text-gray-300 h-64 sm:h-72 overflow-hidden relative\">\n                \n                <div class=\"flex items-center justify-between mb-2 shrink-0\">\n                    <span class=\"font-bold\">Requested Volume:</span>\n                    <span id=\"l30-req-val\" class=\"font-mono text-blue-400 font-black text-sm\">75%</span>\n                </div>\n                \n                <input type=\"range\" min=\"0\" max=\"100\" value=\"75\" class=\"w-full h-1.5 bg-gray-800 rounded appearance-none cursor-pointer accent-blue-500 mb-4 shrink-0\" id=\"l30-req-slider\">\n\n                <div class=\"flex items-center gap-2 mb-2 shrink-0\">\n                    <input type=\"checkbox\" id=\"l30-cb-1\" class=\"w-4 h-4 accent-blue-500 cursor-pointer\">\n                    <label class=\"text-[10px] sm:text-xs\">I have read the penal code</label>\n                </div>\n                <div class=\"flex items-center gap-2 mb-4 shrink-0\">\n                    <input type=\"checkbox\" id=\"l30-cb-2\" class=\"w-4 h-4 accent-blue-500 cursor-pointer\">\n                    <label class=\"text-[10px] sm:text-xs\">I accept full liability</label>\n                </div>\n\n                <button id=\"l30-submit\" class=\"w-full bg-gray-800 hover:bg-gray-700 active:bg-gray-600 text-white font-bold py-3 rounded transition-colors border border-gray-600 shrink-0 focus:outline-none tracking-widest\">SUBMIT FORM 8B</button>\n\n                <div id=\"l30-log\" class=\"text-[9px] sm:text-[10px] font-mono text-gray-500 flex flex-col gap-1 border-t border-gray-800 pt-2 mt-4 overflow-y-auto h-16 shrink-0\">\n                    <div>> System Ready.</div>\n                </div>\n\n                <div id=\"l30-popup-overlay\" class=\"absolute inset-0 bg-gray-900/95 backdrop-blur-sm z-20 hidden flex-col items-center justify-center p-4\">\n                    <div id=\"l30-popup-timer-bar\" class=\"w-full h-1.5 bg-red-600 absolute top-0 left-0 transition-all ease-linear shadow-[0_0_10px_rgba(220,38,38,0.8)]\"></div>\n                    <div id=\"l30-popup-content\" class=\"w-full flex flex-col items-center justify-center gap-3\">\n                        </div>\n                </div>\n            </div>\n\n            <div class=\"mt-1 text-4xl font-mono text-gray-300 text-center w-full shrink-0\" id=\"l30-display\">75%</div>\n        </div>"
}
