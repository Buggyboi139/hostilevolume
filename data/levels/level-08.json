  "display": "flex",
  "html": "        <div id=\"level-8\" class=\"level-ui hidden flex-col items-center justify-center gap-3 w-full min-h-[220px]\">\n            <div class=\"w-full text-[10px] sm:text-xs tracking-widest text-orange-400 uppercase font-bold text-center animate-pulse shrink-0 mb-1\">Rate Limited</div>\n            <button id=\"l8-up\" class=\"p-3 sm:p-4 bg-gray-800 hover:bg-gray-700 active:bg-gray-600 rounded-full transition-colors focus:outline-none\"><svg class=\"w-8 h-8 pointer-events-none\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M5 15l7-7 7 7\"></path></svg></button>\n            <div class=\"text-4xl font-mono text-gray-300 w-24 text-center\" id=\"l8-display\">75%</div>\n            <button id=\"l8-down\" class=\"p-3 sm:p-4 bg-gray-800 hover:bg-gray-700 active:bg-gray-600 rounded-full transition-colors focus:outline-none\"><svg class=\"w-8 h-8 pointer-events-none\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M19 9l-7 7-7-7\"></path></svg></button>\n            <div class=\"w-24 h-1.5 bg-gray-950 rounded-full overflow-hidden mt-1 border border-gray-800\"><div id=\"l8-cooldown-bar\" class=\"h-full bg-blue-500 w-full\"></div></div>\n        </div>"
