{
  "id": "level-13",
  "title": "Tick Tock",
  "display": "flex",
  "html": "        <div id=\"level-13\" class=\"level-ui hidden flex-col items-center justify-center relative w-full h-40 sm:h-48\">\n            <div class=\"absolute top-0 w-full text-[10px] sm:text-xs tracking-widest text-lime-500 uppercase font-bold text-center animate-pulse shrink-0\">Tick Tock</div>\n            <input type=\"range\" min=\"0\" max=\"100\" value=\"75\" class=\"w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-blue-500 mt-6\" id=\"l13-slider\">\n            <div id=\"l13-verify-container\" class=\"hidden flex-col items-center gap-2 w-full mt-4 absolute top-12 sm:top-14\">\n                <span class=\"text-red-400 text-xs sm:text-sm font-bold uppercase tracking-widest animate-pulse\">Verification Required</span>\n                <input type=\"text\" id=\"l13-age-input\" inputmode=\"numeric\" pattern=\"[0-9]*\" placeholder=\"MMDDYYYY\" maxlength=\"8\" class=\"bg-gray-950 border-2 border-red-500 text-white text-center font-mono py-2 px-4 rounded-lg w-40 sm:w-48 focus:outline-none transition-colors shadow-2xl z-10 text-sm sm:text-base\">\n                <span class=\"text-[10px] sm:text-xs text-gray-500 font-mono bg-gray-900 px-2 rounded\">Enter quickly. 3.0s</span>\n            </div>\n            <div class=\"mt-16 text-4xl font-mono text-gray-300 text-center transition-all\" id=\"l13-display\">75%</div>\n        </div>"
}
